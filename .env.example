# -----------------------------------------------------------------------
# Movie Search CLI - Environment Variables Example
# -----------------------------------------------------------------------
# 1. Copy this file and rename the copy to ".env"
# 2. Replace the placeholder value below with your real OMDb API key
# 3. Never commit your real ".env" file to Git (it is already ignored
#    by .gitignore)
# -----------------------------------------------------------------------

# Get a free API key at: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_api_key_here

# Optional overrides (safe to leave as-is)
OMDB_BASE_URL=https://www.omdbapi.com/
REQUEST_TIMEOUT=10
